# ============================================
# CHEZSUA - Environment Variables
# Copy this to .env.local and fill in values
# ============================================

# Site
NEXT_PUBLIC_SITE_URL=https://chezsua.com

# Supabase (https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend - Email (https://resend.com)
RESEND_API_KEY=re_your_resend_key
INQUIRY_TO_EMAIL=chezsuaflower@gmail.com
INQUIRY_FROM_EMAIL=noreply@chezsua.com

# Cloudinary - Optional (https://cloudinary.com)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# 포트원(아임포트) v2 - Payments
NEXT_PUBLIC_PORTONE_STORE_ID=your-store-id
PORTONE_API_SECRET=your-api-secret

# OAuth Providers (NextAuth via Supabase)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Analytics
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_NAVER_ANALYTICS_ID=
